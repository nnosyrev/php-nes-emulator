#!/usr/bin/env php
<?php

use App\CPU\CPU;
use App\Rom\Rom;
use App\Rom\RomInterface;
use DI\Container;

require_once __DIR__ . '/vendor/autoload.php';

$file = file_get_contents($argv[1]);
$rom = new Rom($file);

$container = new Container();
$container->set(RomInterface::class, $rom);

$cpu = $container->get(CPU::class);
$cpu->run();
